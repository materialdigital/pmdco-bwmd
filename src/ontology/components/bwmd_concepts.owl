# Class: :BWMD_0010041 (Austenitization Temperature)

AnnotationAssertion(rdfs:comment :BWMD_0010041 "Aligned to PMDco by Excel mapping: subClassOf 'process attribute'; classification='process attribute'; confidence='high'.")
AnnotationAssertion(rdfs:label :BWMD_0010041 "Austenitization Temperature"@en)
AnnotationAssertion(owl:versionInfo :BWMD_0010041 "This class was added by Elena Garcia Trelles (Fraunhofer IWM)")
AnnotationAssertion(skos:definition :BWMD_0010041 "The temperature at which the steel and ferrous alloys are heated above their critical temperatures is called the austenitizing temperature. Generally the austenitizing temperature ranges from 400°C (752°F) to 800°C (1472°F) for different grades of carbon, alloys and tool steels"@en)
SubClassOf(:BWMD_0010041 :BWMD_0010335)
