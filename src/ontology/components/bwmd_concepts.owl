AnnotationAssertion(owl:versionInfo :BWMD_0010042 "This class was added by Elena Garcia Trelles (Fraunhofer IWM)")
AnnotationAssertion(skos:definition :BWMD_0010042 "Austenitizing is one of the heat treatment processes of steel and other ferrous alloys where these materials are heated above their critical temperatures long enough for transformations to take place. If an austenitized material is followed by a quenching process, then this material becomes hardened"@en)
SubClassOf(:BWMD_0010042 :BWMD_0010332)

