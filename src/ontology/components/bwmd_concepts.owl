AnnotationAssertion(rdfs:label :BWMD_0010316 "Hardening Duration As Supposed"@en)
AnnotationAssertion(owl:versionInfo :BWMD_0010316 "This class was added by Christoph Schweizer (Fraunhofer IWM)")
AnnotationAssertion(skos:definition :BWMD_0010316 "The intended or assumed duration of the hardening process, during which the material is held at the hardening temperature before quenching, typically measured in minutes or hours.
"@en)
SubClassOf(:BWMD_0010316 :BWMD_0010335)

